# Postgres connection string (e.g. from Supabase, Neon, RDS, etc.)
DATABASE_URL="postgresql://user:password@host:5432/louve_luxe"

# S3-compatible object storage (AWS S3, Cloudflare R2, Supabase Storage, MinIO, ...)
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_BUCKET=louve-luxe-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Base URL used to build public links to uploaded files, e.g. https://<bucket>.<endpoint host>
S3_PUBLIC_URL_BASE=

# Anthropic API key, used for AI-assisted floor plan room detection (vision)
ANTHROPIC_API_KEY=

# Markup multiplier applied to cost price to get retail/selling price
SELLING_PRICE_MULTIPLIER=2.4

PORT=3000
